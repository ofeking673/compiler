data $str0 = { b "%d\n", b 0 }
export function w $add(w %a, w %b) {
@start
    %.0 =w add %a, %b
    ret %.0
}
export function w $main() {
@start
    %.1 =l alloc4 20
    %.2 =w add %.1, 0
    storew 1, %.2
    %.3 =w add %.1, 4
    storew 2, %.3
    %.4 =w add %.1, 8
    storew 3, %.4
    %.5 =w add %.1, 12
    storew 4, %.5
    %.6 =w add %.1, 16
    storew 5, %.6
    %i =w copy 1
    jmp @for_loop0
    @for_loop0
      %.7 =w cslew %i, 10
jnz %.7, @for_body1, @for_end2
    @for_body1
            %.8 =l copy $str0
      %.10 =w mul %i, 4
      %.9 =w add , %.10
      call $printf(l %.8, ..., w %.9)
      %i =w add %i, 1
      jmp @for_loop0
    @for_end2
    ret 0
}
